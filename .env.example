# Terminal Server Configuration
# Copy this file to .env and adjust values for your environment.
# Unset values fall back to sensible defaults ($HOME, current user, etc.).

PORT=3000

# Default directory opened in the file browser. Defaults to $HOME/Desktop.
# WORKSPACE_ROOT=/home/your-user/workspace

# User that owns the tmux sessions. Defaults to the user running the server.
# TMUX_USER=your-username

# Shared tmux socket path. All tmux commands use this socket so the service and
# any other tooling share the same set of sessions.
TMUX_SOCKET=/tmp/orchestrator-tmux.sock

# Max file size (bytes) the file viewer will load. Default 6MB.
MAX_FILE_SIZE=6291456

# Where the Claude Code hook writes per-session metadata (status, task, cwd,
# preview URL). Must match the path used by scripts/hooks/terminal-meta.py.
CLAUDE_META_DIR=/tmp/claude-terminal-meta

# Comma-separated extra hosts Vite should accept in dev (e.g. a tunnel domain).
# VITE_ALLOWED_HOSTS=terminal.example.com

# Public URL of the noVNC browser client. When set, /api/config exposes it
# and the frontend renders a "VNC" tab embedding this URL in an iframe.
# Local:   http://localhost:6901/vnc.html
# Tunnel:  https://vnc.example.com/vnc.html
# VNC_URL=http://localhost:6901/vnc.html
